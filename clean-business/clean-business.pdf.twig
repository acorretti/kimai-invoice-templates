{% block invoice_lede %}
    <table class="lede" cellpadding="0" cellspacing="0" width="100%" border="0">
        <tr>
            {% block invoice_address_recipient %}
                <td class="recipient">
                    <address>
                        <strong>{{ customerName }}</strong><br>
                        {% if invoice['customer.contact'] %}
                            {{ invoice['customer.contact'] }}<br>
                        {% endif %}
                        {{ customerAddress|nl2br }}
                        {% set customerCountry = invoice['customer.country']|country_name(invoice['invoice.language']) %}
                        {% if customerCountry not in customerAddress %}
                            <br>{{ customerCountry }}
                        {% endif %}
                        {% if invoice['customer.vat_id'] is not empty %}
                            <br>{{ 'vat_id'|trans }}: {{ invoice['customer.vat_id'] }}
                        {% endif %}
                    </address>
                </td>
            {% endblock %}
            {% block invoice_details %}
                <td class="meta">
                    <h1 class="meta-title">{{ 'invoice'|trans|capitalize }}&nbsp;{{ invoice['invoice.number'] }}</h1>
                    <table class="meta-table" cellpadding="0" cellspacing="0" width="100%" border="0">
                        <tr>
                            <th>{{ 'date'|trans }}</th>
                            <td>{{ invoice['invoice.date'] }}</td>
                        </tr>
                        <tr>
                            <th>{{ 'invoice.due_days'|trans }}</th>
                            <td>{{ invoice['invoice.due_date'] }}</td>
                        </tr>
                        {% if invoice['query.project.order_number'] is defined and invoice['query.project.order_number'] is not empty %}
                            <tr>
                                <th>{{ 'orderNumber'|trans }}</th>
                                <td>{{ invoice['query.project.order_number'] }}</td>
                            </tr>
                        {% endif %}
                    </table>
                </td>
            {% endblock %}
        </tr>
    </table>
{% endblock %}

{% block invoice_content %}
    {% if invoice['customer.invoice_text'] is not empty %}
        <div class="customer-note">{{ invoice['customer.invoice_text']|md2html }}</div>
    {% endif %}

    {% block invoice_content_items %}
        <table class="items" cellpadding="0" cellspacing="0" width="100%" border="0">
            <thead>
                <tr>
                    <th class="date-column">{{ 'date'|trans }}</th>
                    <th class="description">{{ 'description'|trans }}</th>
                    <th class="money-column text-right text-nowrap">{{ 'unit_price'|trans }}</th>
                    <th class="amount-column text-right text-nowrap">{{ 'amount'|trans }}</th>
                    <th class="money-column text-right text-nowrap">{{ 'total_rate'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for invoiceLineItem in entries %}
                    <!-- CONTENT_PART -->
                    <tr>
                        <td class="date-column text-nowrap">{{ invoiceLineItem['entry.begin']|date_short }}</td>
                        <td class="description">
                            {% if invoiceLineItem['entry.description'] is not empty %}
                                {{ invoiceLineItem['entry.description']|nl2br }}
                            {% else %}
                                {% if invoiceLineItem['entry.activity'] is defined %}
                                    {{ invoiceLineItem['entry.activity'] }} /
                                {% endif %}
                                {{ invoiceLineItem['entry.project'] }}
                            {% endif %}
                        </td>
                        <td class="money-column text-right text-nowrap">{{ invoiceLineItem['entry.rate'] }}</td>
                        <td class="amount-column text-right text-nowrap">{{ invoiceLineItem['entry.amount'] }}</td>
                        <td class="money-column text-right text-nowrap">{{ invoiceLineItem['entry.total'] }}</td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-right">{{ 'invoice.subtotal'|trans }}</td>
                    <td class="text-right text-nowrap">{{ invoice['invoice.subtotal'] }}</td>
                </tr>
                {% for taxRow in invoice['invoice.tax_rows'] %}
                    {% if taxRow['show'] %}
                        <tr>
                            <td colspan="4" class="text-right">
                                {{ taxRow['name']|trans }} ({{ taxRow['rate'] }}%)
                                {% if taxRow['note'] is not null %}
                                    <sup>[{{ taxRow['counter'] }}]</sup>
                                {% endif %}
                            </td>
                            <td class="text-right text-nowrap">{{ taxRow['amount']|money(taxRow['currency']) }}</td>
                        </tr>
                    {% endif %}
                {% endfor %}
                <tr class="total-row">
                    <td colspan="4" class="text-right">{{ 'invoice.total'|trans }}</td>
                    <td class="text-right text-nowrap">{{ invoice['invoice.total'] }}</td>
                </tr>
            </tfoot>
        </table>
    {% endblock %}

    {% block invoice_tax_notes %}
        {% for taxRow in invoice['invoice.tax_rows'] %}
            {% if taxRow['note'] is not null %}
                <p class="tax-note"><sup>[{{ taxRow['counter'] }}]</sup> {{ taxRow['note']|trans }}</p>
            {% endif %}
        {% endfor %}
    {% endblock %}

    {% block payment_terms %}
        {% if invoice['template.payment_terms'] is not empty %}
            <div class="paymentTerms">
                {{ invoice['template.payment_terms']|md2html }}
            </div>
        {% endif %}
    {% endblock %}
{% endblock %}
</body>
</html>
